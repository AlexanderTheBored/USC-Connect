# ---- USC Centralized Routing System — Backend .env ----

# Server
PORT=4000
NODE_ENV=development

# PostgreSQL (Railway provides this automatically when you attach a Postgres plugin)
DATABASE_URL=postgresql://user:password@host:5432/database

# Allowed email domain for Google OAuth (do not change unless USC changes theirs)
ALLOWED_EMAIL_DOMAIN=usc.edu.ph

# Google OAuth Client ID — get this from Google Cloud Console
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# JWT signing secret — generate with: openssl rand -hex 64
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,https://rovelportfolio.com,https://www.rovelportfolio.com

# Admin assignments — comma-separated "email:category" pairs.
# On first login, if a user's email matches any entry here, they are created
# as an admin with the mapped category. Categories must be one of:
# Academic, Facilities, Admin/Registrar, IT Services
ADMIN_CONFIG=academic.admin@usc.edu.ph:Academic,facilities.admin@usc.edu.ph:Facilities,registrar.admin@usc.edu.ph:Admin/Registrar,it.admin@usc.edu.ph:IT Services
