# ---- USC Centralized Routing System — Frontend .env ----

# Base URL for the backend API (no trailing slash)
# Local dev:
VITE_API_URL=http://localhost:4000
# Production example (update after you deploy to Railway):
# VITE_API_URL=https://usc-routing-api.up.railway.app

# Google OAuth Client ID — MUST match the one used by the backend
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
